{
  "name": "@chinmaymk/ra",
  "version": "0.0.6",
  "description": "The predictable, observable agent harness.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chinmaymk/ra.git",
    "directory": "packages/ra"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "anthropic",
    "openai",
    "google",
    "ollama",
    "mcp",
    "types"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bun tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "openai": "^6.25.0",
    "@google/generative-ai": "^0.24.1",
    "ollama": "^0.6.3",
    "@aws-sdk/client-bedrock-runtime": "^3.1001.0",
    "@azure/openai": "^2.0.0",
    "@azure/identity": "^4.13.0"
  }
}
