    "@azure/openai": "^2.0.0",
    "@chinmaymk/ra": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "croner": "^10.0.1",
    "js-yaml": "^4.1.1",
    "ollama": "^0.6.3",
    "openai": "^6.25.0",
    "smol-toml": "^1.6.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^3.25 || ^4.0"
