{
  "name": "ra-app",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "ra": "bun run src/index.ts",
    "compile": "bun build src/index.ts --compile --target bun --outfile dist/ra --define __RA_VERSION__='\"'$(bun -e \"process.stdout.write(require('../ra/package.json').version)\")'\"' --define __RA_COMMIT__='\"'$(git rev-parse --short HEAD)'\"'"
