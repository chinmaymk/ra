{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,

    "baseUrl": ".",
    "paths": {
      "@chinmaymk/ra": ["./packages/ra/src/index.ts"],
      "@chinmaymk/ra/*": ["./packages/ra/src/*"],
      "@chinmaymk/ra-workflow": ["./packages/workflow/src/index.ts"],
      "@chinmaymk/ra-workflow/*": ["./packages/workflow/src/*"]
    }
  },
  "exclude": [
    "docs",
    "dist"
  ]
}
