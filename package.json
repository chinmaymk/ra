{
  "name": "ra-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ra": "bun run packages/app/src/index.ts",
    "compile": "cd packages/app && bun run compile",
    "build": "cd packages/ra && bun run build",
    "test": "bun test packages/ra/tests packages/app/tests"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5"
  }
}
