{
  "name": "@chinmaymk/ra",
  "version": "0.0.3",
  "description": "One loop. Infinite agents. Type definitions for the ra AI agent framework.",
  "type": "module",
  "types": "dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chinmaymk/ra.git"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "mcp",
    "anthropic",
    "openai",
    "google",
    "ollama",
    "types"
  ],
  "scripts": {
    "build:types": "tsc -p tsconfig.build.json",
    "compile": "bun build src/index.ts --compile --target bun --outfile dist/ra --define __RA_VERSION__='\"'$(node -p \"require('./package.json').version\")'\"' --define __RA_COMMIT__='\"'$(git rev-parse --short HEAD)'\"'",
    "ra": "bun run src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1001.0",
    "@azure/identity": "^4.13.0",
    "@azure/openai": "^2.0.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.1.1",
    "ollama": "^0.6.3",
    "openai": "^6.25.0",
    "smol-toml": "^1.6.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
